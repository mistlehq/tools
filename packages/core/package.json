{
  "name": "@mistle-tools/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "mkdir -p dist && bun build src/index.ts --outfile dist/index.js && tsc -p tsconfig.json --emitDeclarationOnly",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run",
    "typecheck": "tsgo -p tsconfig.json --noEmit"
  }
}
