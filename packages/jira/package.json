{
  "name": "@mistle-tools/jira",
  "version": "0.1.0",
  "private": false,
  "bin": {
    "jira": "./dist/bin/jira"
  },
  "type": "module",
  "scripts": {
    "build": "mkdir -p dist/bin && bun build src/index.ts --compile --outfile dist/bin/jira",
