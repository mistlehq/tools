# Copy to .env.local and fill in real credentials for local integration tests.
#
# The CLIs do not inject auth headers themselves. Integration tests use these
# values to start a local proxy that injects auth while the CLI only sees
# JIRA_BASE_URL pointing at that proxy.

JIRA_TEST_UPSTREAM_BASE_URL=https://mistle.atlassian.net
JIRA_TEST_USERNAME=your-atlassian-email@example.com
JIRA_TEST_PASSWORD=your-atlassian-api-token
JIRA_TEST_TEMPLATE_ISSUE_KEY=KAN-948
